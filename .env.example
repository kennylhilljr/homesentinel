# HomeSentinel Environment Configuration
# Copy this file to .env and fill in your actual values.
# Env vars take priority over credentials stored in the database.

# Backend Configuration
BACKEND_PORT=8443
BACKEND_HOST=0.0.0.0

# Frontend Configuration
REACT_APP_API_URL=https://localhost:8443
REACT_APP_WS_URL=wss://localhost:8443

# Deco Router Credentials
DECO_USERNAME=your_tp_link_email
DECO_PASSWORD=your_tp_link_password
DECO_MODE=cloud                           # "cloud" or "local"
# DECO_LOCAL_ENDPOINT=https://192.168.0.1  # only needed for local mode
# DECO_NAME_SYNC_INTERVAL=300             # seconds between name sync cycles

# Amazon Alexa (Login with Amazon OAuth)
ALEXA_CLIENT_ID=amzn1.application-oa2-client.xxxxx
ALEXA_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxx

# Chester Router (ImmortalWrt/OpenWrt)
CHESTER_HOST=192.168.12.1
CHESTER_PORT=80
CHESTER_USERNAME=admin
CHESTER_PASSWORD=your_chester_router_password
# CHESTER_USE_HTTPS=false
# CHESTER_VERIFY_SSL=false

# Network Scanning
NETWORK_SUBNET=192.168.12.0/24
POLLING_INTERVAL_SECONDS=60

# Logging
LOG_LEVEL=INFO
